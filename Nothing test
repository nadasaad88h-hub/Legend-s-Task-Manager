// Logic for handling the rolling 1-hour skip limit
function canUserSkip(db) {
    const now = Date.now();
    const oneHour = 3600000;
    
    // Filter out skips older than 1 hour
    if (!db.skips.history) db.skips.history = [];
    db.skips.history = db.skips.history.filter(timestamp => (now - timestamp) < oneHour);
    
    return db.skips.history.length < 3;
}

