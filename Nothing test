> A 50/50 chance to win 40 points or lose 10. (ID: \`mystery\`)
**5. Booster Badge** — 10 Points
> Get a temporary "Store Supporter" badge next to your name. (ID: \`badge\`)
`;
        return interaction.reply({ content: storeFront, ephemeral: true });
    }

    // --- STORE COMMAND: BUY ---
    if (interaction.commandName === 'buy_item') {
        const item = interaction.options.getString('item_id');
        const shopLogs = client.channels.cache.get(CHANNELS.LOGS);

        // Helper to handle point deduction and logging without double-replying
        const checkAndDeduct = async (cost, itemName) => {
            if (db.points < cost) return { success: false, error: `❌ You need **${cost} Points**, but you only have **${db.points}**.` };
            
            db.points -= cost;
            await db.save();
            if (shopLogs) shopLogs.send(`🛍️ **New Purchase**: <@${interaction.user.id}> bought **${itemName}** for ${cost} points.`);
            return { success: true };
        };

        switch (item) {
            case 'color': {
                const result = await checkAndDeduct(50, "Custom Role Color");
                if (!result.success) return interaction.reply({ content: result.error, ephemeral: true });
                return interaction.reply({ content: "✅ Purchase successful! Please DM a Manager with your desired Hex Code.", ephemeral: true });
            }

            case 'priority': {
                const result = await checkAndDeduct(30, "Priority Ticket");
                if (!result.success) return interaction.reply({ content: result.error, ephemeral: true });
                
                db.tags = db.tags || [];
                if (!db.tags.includes("Priority")) db.tags.push("Priority");
                db.markModified('tags');
                await db.save();
                return interaction.reply({ content: "✅ You now have **Priority Ticket** status!", ephemeral: true });
            }

            case 'wipe': {
                const activeWarning = db.punishments.find(p => p.active && (p.type === 'Verbal' || p.type === 'Staff'));
                if (!activeWarning) return interaction.reply({ content: "❌ You don't have any active warnings to wipe!", ephemeral: true });
                
                const result = await checkAndDeduct(150, "Punishment Wipe");
                if (!result.success) return interaction.reply({ content: result.error, ephemeral: true });

                activeWarning.active = false;
                db.markModified('punishments');
                await db.save();
                return interaction.reply({ content: `✅ Successfully wiped Case **#${activeWarning.caseNumber}** from your active record.`, ephemeral: true });
            }

            case 'mystery': {
                const result = await checkAndDeduct(20, "Mystery Box");
                if (!result.success) return interaction.reply({ content: result.error, ephemeral: true });

                const win = Math.random() > 0.5;
                if (win) {
                    db.points += 40;
                    await db.save();
                    return interaction.reply({ content: "🎁 **JACKPOT!** You won **40 Points**!", ephemeral: true });
                } else {
                    return interaction.reply({ content: "💨 The box was empty. Better luck next time!", ephemeral: true });
                }
            }

            case 'badge': {
                const result = await checkAndDeduct(10, "Booster Badge");
                if (!result.success) return interaction.reply({ content: result.error, ephemeral: true });
                return interaction.reply({ content: "✨ Enjoy your new **Store Supporter** badge in the shop records!", ephemeral: true });
            }

            default:
                return interaction.reply({ content: "❓ Unknown Item ID. Use \`/view_store\` to see valid IDs.", ephemeral: true });
        }
    }

    // --- QUOTA SYSTEM: ADD ---
    if (interaction.commandName === 'add_quota') {
        if (!interaction.member.roles.cache.has("1494275716043374743")) {
            return interaction.reply({ content: "❌ Only Management can update quotas.", ephemeral: true });
        }

        const targetUser = interaction.options.getUser('user');
        const amount = interaction.options.getInteger('amount');
        const targetDB = await getDB(targetUser.id);

        targetDB.quota = (targetDB.quota || 0) + amount;
        await targetDB.save();

        return interaction.reply({ content: `✅ Added **${amount}** to <@${targetUser.id}>'s weekly quota. (Total: ${targetDB.quota})`, ephemeral: true });
    }

    // --- QUOTA SYSTEM: VIEW ---
    if (interaction.commandName === 'view_quota') {
        const target = interaction.options.getUser('user') || interaction.user;
        const targetDB = await getDB(target.id);
        const currentQuota = targetDB.quota || 0;
        const requirement = 10; 

        const status = currentQuota >= requirement ? "✅ **Met**" : "⚠️ **Incomplete**";

        return interaction.reply({
            content: `### Staff Quota: <@${target.id}>\n**Current Progress:** ${currentQuota} / ${requirement}\n**Status:** ${status}`,
            ephemeral: true
        });
    }

    // --- GIVEAWAY START ---
    if (interaction.commandName === 'giveaway_start') {
        // Management Permission Check (Head of Promotions Role)
        if (!interaction.member.roles.cache.has("1494275716043374743")) {
            return interaction.reply({ content: "❌ You do not have permission to start giveaways.", ephemeral: true });
        }

        const prize = interaction.options.getString('prize');
        const duration = interaction.options.getInteger('duration'); 
        const winnerCount = interaction.options.getInteger('winners') || 1;
        const channel = interaction.options.getChannel('channel') || interaction.channel;

        const endTime = Date.now() + (duration * 60 * 1000);
        const giveawayEntries = new Set();

        const embed = {
            title: "🎁 NEW GIVEAWAY!",
            description: `**Prize:** ${prize}\n**Winners:** ${winnerCount}\n**Ends:** <t:${Math.floor(endTime / 1000)}:R>\n**Hosted By:** ${interaction.user}`,
            color: 0x5865F2,
            footer: { text: "Click the button below to enter!" }
        };

        const row = {
            type: 1,
            components: [{
                type: 2, label: "Enter Giveaway", style: 1, custom_id: `giveaway_enter_${interaction.id}`
            }]
        };

        const msg = await channel.send({ embeds: [embed], components: [row] });
        await interaction.reply({ content: "✅ Giveaway started!", ephemeral: true });

        // Collector for entries
        const collector = msg.createMessageComponentCollector({ 
            filter: i => i.customId === `giveaway_enter_${interaction.id}`,
            time: duration * 60 * 1000 
        });

        collector.on('collect', async i => {
            if (giveawayEntries.has(i.user.id)) {
                return i.reply({ content: "⚠️ You have already entered this giveaway!", ephemeral: true });
            }
            giveawayEntries.add(i.user.id);
            await i.reply({ content: "✅ You have successfully entered the giveaway!", ephemeral: true });
        });

        collector.on('end', async () => {
            const participants = Array.from(giveawayEntries);
            const winners = [];

            if (participants.length < winnerCount) {
                const disabledRow = { type: 1, components: [{ type: 2, label: "Giveaway Ended", style: 2, custom_id: "ended", disabled: true }] };
                await msg.edit({ components: [disabledRow] });
                return channel.send(`⚠️ Giveaway ended, but there weren't enough participants for **${prize}**.`);
            }

            for (let i = 0; i < winnerCount; i++) {
                const pick = participants.splice(Math.floor(Math.random() * participants.length), 1)[0];
                winners.push(`<@${pick}>`);
            }

            const disabledRow = {
                type: 1,
                components: [{
                    type: 2, label: "Giveaway Ended", style: 2, custom_id: "ended", disabled: true
                }]
            };

            await msg.edit({ components: [disabledRow] });
            channel.send(`🎉 **Giveaway Ended!**\n**Prize:** ${prize}\n**Winners:** ${winners.join(', ')}\nCongratulations!`);
        });
    }

client.on('messageCreate', async (message) => {
    // Only trigger in the specific Counting channel
    if (message.author.bot || message.channel.id !== CHANNELS.COUNTING) return;

    // Use findOneAndUpdate to prevent race conditions (two people counting at once)
    const globalDB = await Global.findOneAndUpdate(
        { guildId: message.guild.id },
        { $setOnInsert: { currentCount: 0, lastCounter: "" } },
        { upsert: true, new: true }
    );

    const userNumber = parseInt(message.content);
    const nextNumber = globalDB.currentCount + 1;

    if (isNaN(userNumber)) return;

    // Error: Wrong Number or Double Counting
    if (userNumber !== nextNumber || globalDB.lastCounter === message.author.id) {
        let errorMsg = userNumber !== nextNumber 
            ? `❌ **WRONG NUMBER!** <@${message.author.id}> ruined it at **${userNumber}**.` 
            : `🚫 **STRICT RULE:** <@${message.author.id}>, you cannot count twice in a row!`;
            
        globalDB.currentCount = 0;
        globalDB.lastCounter = "";
        await globalDB.save();
        message.react("❌");
        return message.reply(`${errorMsg} The count has been reset to **0**.`);
    }

    // Success
    globalDB.currentCount = nextNumber;
    globalDB.lastCounter = message.author.id;
    await globalDB.save();
    message.react("✅");

    // Milestone Reward (Every 50 counts)
    if (nextNumber % 50 === 0) {
        const userDB = await getDB(message.author.id);
        userDB.points += 5;
        await userDB.save();
        message.channel.send(`🎊 **MILESTONE!** We reached **${nextNumber}**! <@${message.author.id}> earned **5 Points**.`);
    }
});

