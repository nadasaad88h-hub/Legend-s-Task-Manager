        } else if (punishment.type === 'Termination') {
            revertDM = `🟤 Termination Reverted  \n\n## LAGGING LEGENDS COMMUNITY — OFFICIAL NOTICE OF PUNISHMENT REVERSAL\n\nHello, ${targetMention}\n\nYour Termination issued by the Lagging Legends Server Administration has been reverted, and your staff position within Lagging Legends Community has been restored.\n\nReason: ${reason}  \nEvidence: ${evidence}\n\nThis restoration in Lagging Legends Community is conditional and may be revoked if expectations are not met.`;
        } else if (punishment.type === 'Kick') {
            revertDM = `⚫️ Kick Record Removed  \n\n## LAGGING LEGENDS COMMUNITY — OFFICIAL NOTICE OF PUNISHMENT REVERSAL\n\nHello, ${targetMention}\n\nYour Kick issued by the Lagging Legends Server Administration has been removed from your moderation logs within Lagging Legends Community. This record no longer appears in your official history.\n\nReason: ${reason}  \nEvidence: ${evidence}\n\nRepeated disruptive behavior in Lagging Legends Community may result in stronger disciplinary action, including mute, suspension, or ban.`;
        } else if (punishment.type === 'Ban') {
            revertDM = `⚫️ Ban Reverted  \n\n## LAGGING LEGENDS COMMUNITY — OFFICIAL NOTICE OF PUNISHMENT REVERSAL\n\nHello, ${targetMention}\n\nYour Ban from Lagging Legends issued by the Lagging Legends Server Administration has been reverted, and your access to Lagging Legends Community has been restored.\n\nReason: ${reason}  \nEvidence: ${evidence}\n\nThis reinstatement in Lagging Legends Community is conditional. Further severe violations may result in permanent removal without additional warning.`;
        }

        try { await targetUser.send(revertDM); } catch (e) { }

        // Log the Reversal
        const logChan = client.channels.cache.get(CHANNELS.LOGS);
        if (logChan) {
            logChan.send(`✅ **Punishment Reverted**\n**Original Case:** #${caseId}\n**Target:** ${targetUser.tag}\n**Reverted By:** ${interaction.user.tag}\n**Reason:** ${reason}`);
        }

        return interaction.reply({ content: `✅ Punishment for Case #${caseId} has been successfully reverted.`, ephemeral: true });
    }

    // --- STORE COMMAND: VIEW ---
    if (interaction.commandName === 'view_store') {
        const storeFront = `
## 🛒 LAGGING LEGENDS OFFICIAL STORE
*Use \`/buy_item [item_id]\` to purchase.*

**1. Custom Role Color** — 50 Points
> Get a unique color for your name in the member list. (ID: \`color\`)
**2. Priority Ticket** — 30 Points
> Your tickets will be moved to the top of the queue. (ID: \`priority\`)
**3. Punishment Wipe** — 150 Points
> Removes one 'Active' Verbal or Staff Warning from your record. (ID: \`wipe\`)
